@model CapaEntidad.Producto
@{
    ViewBag.Title = "DetalleProducto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5">
    <div class="container px-4 px-lg-5 my-5">
        <div class="row gx-4 gx-lg-5 align-items-center">
            <div class="col-md-6">
                <img class="card-img-top mb-5 mb-md-0"
                     src="@(string.IsNullOrEmpty(Model.Base64)
                        ? "https://upload.wikimedia.org/wikipedia/commons/thumb/2/2c/Eo_circle_grey_not-allowed.svg/2048px-Eo_circle_grey_not-allowed.svg.png"
                        : $"data:image/{Model.Extension.Replace(".", "")};base64,{Model.Base64}")"
                     alt="Imagen del producto" />
            </div>
            <div class="col-md-6">
                <div class="small mb-1 text-white-75">Marca: @Html.DisplayTextFor(m => m.oMarca.Descripcion)</div>
                <h1 class="display-5 fw-bolder text-white-75">@Html.DisplayTextFor(m => m.Nombre)</h1>
                <div class="fs-5 mb-5">
                    @*<span class="text-decoration-line-through">$45.00</span>*@
                    <span class="text-white-75">@Html.DisplayTextFor(m => m.oDetalle.PrecioVenta) USD</span>
                </div>
                <p class="lead text-white-75">@Html.DisplayTextFor(m => m.Descripcion)</p>
                <div class="d-flex">
                    <a href="@Url.Action("Index","Tienda")" class="btn btn-danger w-50 text-center me-3">
                        <i class="fas fa-undo-alt"></i> Volver
                    </a>

                    @if (Session["Usuario"] != null)
                    {
                        <button class="btn btn-success agregarcarrito flex-shrink-0 w-50" type="button" data-idproducto="@Html.DisplayTextFor(m => m.IdProducto)">
                            <i class="fas fa-cart-plus"></i>
                            Agregar a carrito
                        </button>
                    }

                </div>
            </div>
        </div>
    </div>
</section>

@section scripts{
<script>

    $(document).on("click", "button.agregarcarrito", function () {

        console.log($(this).data("idproducto"))

        jQuery.ajax({
            url: '@Url.Action("AgregarCarrito", "Tienda")',
            type: "POST",
            data: JSON.stringify({ idproducto: $(this).data("idproducto") }),
            dataType: "json",
            contentType: "application/json; charset=utf-8",
            success: function (data){

                if (data.respuesta) {
                    MonstrarCantidadCarrito()

                    swal({
                        title: "Agregado al carrito",
                        text: "¿Desea ir al carrito?",
                        type: "success",
                        showCancelButton: true,
                        confirmButtonClass: "btn-primary",
                        confirmButtonText: "Si",
                        cancelButtonText: "No",
                        closeOnConfirm: true

                    }, function () {

                        window.location.href = '@Url.Action("Carrito", "Tienda")'

                    })
                    //swal("", "Agregado al carrito", "success");
                }
                else {
                    swal("", data.mensaje, "warning");
                }
            }
        });
    })

</script>
}