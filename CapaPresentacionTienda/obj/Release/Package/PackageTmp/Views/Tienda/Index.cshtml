
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header-->
<section id="sInicio">
    <header class="bg-dark p-md-4">
        <div class="container px-4 px-lg-5 my-5">
            <div class="text-center text-white">
                <h1 class="display-4 fw-bolder">Bienvenidos a CYG</h1>
                @*<p class="lead fw-normal text-white-50 mb-0">descripcion</p>*@
            </div>
        </div>
    </header>
    <hr class="divider" />
</section>

<!--Masthead-->
<header class="masthead">
    <div class="container px-4 px-lg-5 h-100">
        <div class="row gx-4 gx-lg-5 h-100 align-items-center justify-content-center text-center">
            <div class="col-lg-8 align-self-end">
                <h2 class="text-white font-weight-bold">Consigue aquí lo que necesites!</h2>
                <hr class="divider" />
            </div>
            <div class="col-lg-8 align-self-baseline">
                <p class="text-white-75 mb-5">Descripción personalizada</p>
                <a class="btn btn-primary btn-xl" href="@Url.Action("Blog","Tienda")">Saber más</a>
            </div>
        </div>
    </div>
</header>



<!-- Catálogo-->
<section id="sProductos">
    <div class="bg-dark ">
        <div class="container px-4 px-lg-5 my-5">
            <div class="text-center text-white">
                <h3 class="display-4 fw-bolder">Catálogo</h3>
                <p class="lead fw-normal text-white-50 mb-0">Encuentra los mejores productos!</p>
            </div>
        </div>
    </div>

    <!-- Section Catálogo -->
    <section>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <h3 class="text-white">Filtrar por:</h3>

                    <!--Filtros-->
                    <div class="row g-3 mb-3 align-items-end">

                        <div class="col-12 col-md-2">
                            <p class="text-white mb-1">Categorías</p>
                            <div id="contenedorCategoria"></div>
                        </div>

                        <div class="col-12 col-md-2">
                            <p class="text-white mb-1">Marcas</p>
                            <div id="contenedorMarca"></div>
                        </div>

                        <div class="col-12 col-md-4">
                            <p class="text-white mb-1">Buscar</p>
                            <input id="txtBuscar" class="form-control" type="text">
                        </div>

                        <div class="col-6 col-md-2">
                            <button id="btnAplicarFiltro" class="btn btn-outline-success w-100">
                                <i class="fas fa-filter"></i> Aplicar Filtros
                            </button>
                        </div>
                        <div class="col-6 col-md-2">
                            <button id="btnLimpiarFiltro" class="btn btn-outline-info w-100">
                                <i class="fas fa-arrow-alt-circle-left"></i> Limpiar Filtros
                            </button>
                        </div>

                    </div>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-sm-10 pt-5">
                    <div id="contenedorProducto" class="row gx-4 gx-lg-4 row-cols-2 row-cols-md-3 row-cols-xl-4  justify-content-center">



                        <div class="col mb-5">
                            <div class="card h-100">
                                <!-- Product image-->
                                <img class="card-img-top" src="https://dummyimage.com/450x300/dee2e6/6c757d.jpg" alt="..." />
                                <!-- Product details-->
                                <div class="card-body p-4">
                                    <div class="text-center">
                                        <!-- Product name-->
                                        <h5 class="fw-bolder">Producto</h5>
                                        <!-- Product price-->
                                        $00.00 - $00.00
                                    </div>
                                </div>
                                <!-- Product actions-->
                                <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                                    <div class="text-center"><a class="btn btn-outline-dark mt-auto" href="#">Detalle</a></div>
                                </div>
                            </div>
                        </div>
                        <div class="col mb-5">
                            <div class="card h-100">
                                <!-- Sale badge-->
                                <div class="badge bg-dark text-white position-absolute" style="top: 0.5rem; right: 0.5rem">Sale</div>
                                <!-- Product image-->
                                <img class="card-img-top" src="https://dummyimage.com/450x300/dee2e6/6c757d.jpg" alt="..." />
                                <!-- Product details-->
                                <div class="card-body p-4">
                                    <div class="text-center">
                                        <!-- Product name-->
                                        <h5 class="fw-bolder">Special Item</h5>
                                        <!-- Product reviews-->
                                        <div class="d-flex justify-content-center small text-warning mb-2">
                                            <div class="bi-star-fill"></div>
                                            <div class="bi-star-fill"></div>
                                            <div class="bi-star-fill"></div>
                                            <div class="bi-star-fill"></div>
                                            <div class="bi-star-fill"></div>
                                        </div>
                                        <!-- Product price-->
                                        <span class="text-muted text-decoration-line-through">$20.00</span>
                                        $18.00
                                    </div>
                                </div>
                                <!-- Product actions-->
                                <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                                    <div class="text-center"><a class="btn btn-outline-dark mt-auto" href="#">Add to cart</a></div>
                                </div>
                            </div>
                        </div>


                    </div>
                    <div class="row">
                        <div class="col-12 d-flex justify-content-center mt-4">
                            <ul id="paginacion" class="pagination"></ul>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</section>



@section scripts{



    <script>

        var paginaActual = 1;
        var productosPorPagina = 12;

        $(document).ready(function () {
            MostrarCategorias();
            MostrarProductos(0, 0, 1);
        })

        //ListaCategorias
        function MostrarCategorias() {
            jQuery.ajax({
                url: "@Url.Action("ListaCategorias", "Tienda")",
                type: "GET",
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (response) {

                    $("#contenedorCategoria").empty();
                    $("#contenedorCategoria").LoadingOverlay("hide");

                    // Crear select
                    var select = $("<select>")
                        .addClass("form-select")
                        .attr({
                            "id": "selectCategoria",
                            "name": "categoria"
                        });

                    // Opción Inicial
                    select.append(
                        $("<option>")
                            .val(0)
                            .text("Todas")
                    );

                    // Opciones dinámicas
                    $.each(response.data, function (i, element) {
                        select.append(
                            $("<option>")
                                .val(element.IdCategoria)
                                .text(element.Descripcion)
                        );
                    });

                    // Agregar select al contenedor
                    $("#contenedorCategoria").append(select);

                    MostrarMarcas();

                },
                beforeSend: function () {
                    $("#contenedorCategoria").LoadingOverlay("show");
                }
            });
        }

        //ListarMarcaPorCategoria
        function MostrarMarcas() {

            var _idcategoria = $("#selectCategoria").val();

            jQuery.ajax({
                url: "@Url.Action("ListarMarcaPorCategoria", "Tienda")",
                type: "POST",
                data: JSON.stringify({ idcategoria : _idcategoria }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (response) {

                    $("#contenedorMarca").empty();
                    $("#contenedorMarca").LoadingOverlay("hide");

                    // Crear select de marcas
                    var select = $("<select>")
                        .addClass("form-select")
                        .attr({
                            "id": "selectMarca",
                            "name": "marca"
                        });

                    // Opción Inicial
                    select.append(
                        $("<option>")
                            .val(0)
                            .text("Todas")
                    );

                    // Opciones dinámicas
                    $.each(response.data, function (i, element) {
                        select.append(
                            $("<option>")
                                .val(element.IdMarca)
                                .text(element.Descripcion)
                        );
                    });

                    // Agregar al contenedor
                    $("#contenedorMarca").append(select);
                },
                beforeSend: function () {
                    $("#contenedorMarca").LoadingOverlay("show");
                }
            })
        }

        // Acción de actualizar la lista de selección de marcas al seleccionar una categoría.
        $(document).on("change", "#selectCategoria", function () {
            MostrarMarcas();
            //MostrarProductos($(this).val(), 0, 1);  //para que filtre automáticamente al seleccionar una categoria
        });

        //Filtro
        $("#btnAplicarFiltro").click(function () {
            var _idcategoria = $("#selectCategoria").val();
            var _idmarca = $("#selectMarca").val();
            var _texto = $("#txtBuscar").val().trim();
            MostrarProductos(_idcategoria, _idmarca, 1, _texto);
        });

        $("#btnLimpiarFiltro").click(function () {
            $("#selectCategoria").val(0);
            $("#selectMarca").val(0);
            $("#txtBuscar").val("");
            MostrarProductos(0, 0, 1, "");
        })

        $("#txtBuscar").on("keypress", function (e) {
            if (e.which === 13) { // Enter
                e.preventDefault(); // evita comportamientos raros
                $("#btnAplicarFiltro").click();
            }
        });


        //Listar Productos
        function MostrarProductos(_idcategoria, _idmarca, pagina = 1, textoBusqueda = "") {

            paginaActual = pagina;

            jQuery.ajax({
                url: "@Url.Action("ListarProductos", "Tienda")",
                type: "POST",
                data: JSON.stringify({
                    idcategoria: _idcategoria, idmarca: _idmarca, texto: textoBusqueda, pagina: paginaActual, cantidad: productosPorPagina }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (response) {

                    $("#contenedorProducto").html("");
                    $("#contenedorProducto").LoadingOverlay("hide");



                    $.each(response.data, function (i, element) {

                        const nombre = String(element.NombreImagen ?? "");

                        const src = "@Url.Content("~/Images/")" + nombre;

                        $("<div>").addClass("col mb-5").append(
                            $("<div>").addClass("card h-100").append(
                                $("<img>").addClass("card-img-top").attr("src", src)
                                    .on("error", function () {
                                        $(this).attr("src", "https://static.vecteezy.com/system/resources/previews/022/059/000/non_2x/no-image-available-icon-vector.jpg");
                                    }),
                                $("<div>").addClass("card-body p-4").append(
                                    $("<div>").addClass("text-center").append(
                                        $("<h5>").addClass("fw-bolder").text(element.Nombre),
                                        "$ " + element.oDetalle.PrecioVenta.toFixed(2) + "USD"
                                    )
                                ),
                                $("<div>").addClass("card-footer p-2 pt-0 border-top-0 bg-transparent").append(
                                    $("<div>").addClass("d-grid gap-2").append(

                                        @if (Session["Usuario"] != null)
                                        {
                                            @:$("<button>").addClass("btn btn-success mt-auto agregarcarrito").data("idproducto", element.IdProducto).text("Agregar a carrito"),
                                        }

                                        $("<a>").addClass("btn btn-dark mt-auto")
                                            .attr({ "href": "@Url.Action("DetalleProducto","Tienda")" + "?idproducto=" + element.IdProducto })
                                            .text("Ver detalle")
                                    )
                                )
                            )
                        ).appendTo("#contenedorProducto")

                    });
                    ConstruirPaginacion(response.total);
                },
                beforeSend: function () {
                    $("#contenedorProducto").LoadingOverlay("show");
                }
            })
        }


        //Paginación
        function ConstruirPaginacion(totalRegistros) {

            $("#paginacion").empty();

            var totalPaginas = Math.ceil(totalRegistros / productosPorPagina);

            // Botón Inicio
            $("<li>").addClass("page-item")
                .append(
                    $("<a>").addClass("page-link").text("Inicio").click(function () {
                        MostrarProductos(
                            $("#selectCategoria").val(),
                            $("#selectMarca").val(),
                            1
                        );
                    })
                )
                .appendTo("#paginacion");

            // Botones intermedios
            for (let i = 1; i <= totalPaginas; i++) {
                $("<li>").addClass("page-item " + (i === paginaActual ? "active" : ""))
                    .append(
                        $("<a>").addClass("page-link").text(i).click(function () {
                            MostrarProductos(
                                $("#selectCategoria").val(),
                                $("#selectMarca").val(),
                                i
                            );
                        })
                    )
                    .appendTo("#paginacion");
            }

            // Botón Fin
            $("<li>").addClass("page-item")
                .append(
                    $("<a>").addClass("page-link").text("Fin").click(function () {
                        MostrarProductos(
                            $("#selectCategoria").val(),
                            $("#selectMarca").val(),
                            totalPaginas
                        );
                    })
                )
                .appendTo("#paginacion");
        }





        //AgregarCarrito
        $(document).on("click", "button.agregarcarrito", function () {

            console.log($(this).data("idproducto"))

            jQuery.ajax({
                url: '@Url.Action("AgregarCarrito", "Tienda")',
                type: "POST",
                data: JSON.stringify({ idproducto: $(this).data("idproducto") }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (data){

                    if (data.respuesta) {
                        MonstrarCantidadCarrito()

                        swal({
                            title: "Agregado al carrito",
                            text: "¿Desea ir al carrito?",
                            type: "success",
                            showCancelButton: true,
                            confirmButtonClass: "btn-primary",
                            confirmButtonText: "Si",
                            cancelButtonText: "No",
                            closeOnConfirm: true

                        }, function () {

                            window.location.href = '@Url.Action("Carrito", "Tienda")'

                        })
                    }
                    else {
                        swal("", data.mensaje, "warning");
                    }
                }
            });
        })


    </script>



}


<style>

    .card-img-top {
        height: 220px;
        object-fit: contain;
        background-color: #f8f9fa; /* gris Bootstrap */
        padding: 10px;
    }
</style>
