@model CapaEntidad.Producto

@{
    ViewData["Title"] = "Detalle del Producto";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item active">Detalle</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-boxes me-1"></i> Detalle del Producto
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-12">
                @Html.ActionLink("Volver", "Producto", null, new { @class = "btn btn-outline-secondary ms-2" })
            </div>
        </div>

        <hr class="mb-5" />


        <div class="row">

            <div class="col-sm-6">

                <dl class="row">

                    <dt class="col-sm-5">
                        Nombre:
                    </dt>
                    <dd class="col-sm-5">
                        @Html.DisplayFor(model => model.Nombre)
                    </dd>
                    <hr class="m-0" />


                    <dt class="col-sm-5">
                        Descripcion:
                    </dt>
                    <dd class="col-sm-5">
                        @Html.DisplayFor(model => model.Descripcion)
                    </dd>
                    <hr class="m-0" />


                    <dt class="col-sm-5">
                        Marca:
                    </dt>
                    <dd class="col-sm-5">
                        @Html.DisplayFor(model => model.oMarca.Descripcion)
                    </dd>
                    <hr class="m-0" />


                    <dt class="col-sm-5">
                        Categoría:
                    </dt>
                    <dd class="col-sm-5">
                        @Html.DisplayFor(model => model.oCategoria.Descripcion)
                    </dd>
                    <hr class="m-0" />


                    <dt class="col-sm-5">
                        Precio de compra:
                    </dt>
                    <dd class="col-sm-5">
                        $ @Html.DisplayFor(model => model.oDetalle.PrecioCompra)
                    </dd>
                    <hr class="m-0" />


                    <dt class="col-sm-5">
                        Precio de venta:
                    </dt>
                    <dd class="col-sm-5">
                        $ @Html.DisplayFor(model => model.oDetalle.PrecioVenta)
                    </dd>
                    <hr class="m-0" />


                    <dt class="col-sm-5">
                        Cantidad de compra:
                    </dt>
                    <dd class="col-sm-5">
                        @Html.DisplayFor(model => model.oDetalle.CantidadCompra)
                    </dd>
                    <hr class="m-0" />


                    <dt class="col-sm-5">
                        Stock:
                    </dt>
                    <dd class="col-sm-5">
                        @Html.DisplayFor(model => model.Stock)
                    </dd>
                    <hr class="m-0" />


                    <dt class="col-sm-5">
                        @Html.DisplayNameFor(model => model.Activo):
                    </dt>
                    <dd class="col-sm-5">
                        @(Model.Activo ? "Sí" : "No")
                    </dd>
                </dl>
            </div>


            <div class="col-sm-4">
                <dt class="m-0">
                    Imagen
                </dt>
                <hr class="m-0" />
                <img 
                    @*src="@Url.Content($"{Model.RutaImagen}{Model.NombreImagen}")"*@ 
                    src=@(string.IsNullOrEmpty(Model.Base64))
                        ?  "https://static.vecteezy.com/system/resources/previews/022/059/000/non_2x/no-image-available-icon-vector.jpg"
                        : $"data:image/{Model.Extension.Replace(".", "")};base64,{Model.Base64}")"
                    id="imgProducto" alt="Imagen del producto" class="img-thumbnail" style="max-width:300px;"
                    loading="lazy"
                    onerror="this.src='https://static.vecteezy.com/system/resources/previews/022/059/000/non_2x/no-image-available-icon-vector.jpg'" />
            </div>
        </div>

    </div>
</div>



