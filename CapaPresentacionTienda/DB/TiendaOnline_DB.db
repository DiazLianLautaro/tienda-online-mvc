/****** Object:  StoredProcedure [dbo].[sp_RegistrarProducto]    Script Date: 8/4/2026 18:33:47 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
create proc [dbo].[sp_RegistrarProducto](
@Nombre varchar(100),
@Descripcion varchar(100),
@IdMarca varchar(100),
@IdCategoria varchar(100),
@Stock int,
@Activo bit,
@PrecioCompra decimal(10,2),
@PrecioVenta decimal(10,2),
@CantidadCompra int,
@Mensaje varchar(500) output,
@Resultado int output
)
as
begin try

	begin tran
		declare @IdAutogenerado int;

		set @Resultado = 0
		if not exists (select 1 from PRODUCTO where Nombre = @Nombre)
		begin
			insert into PRODUCTO (Nombre, Descripcion, MarcaId, CategoriaId, Stock, Activo) values
			(@Nombre, @Descripcion, @IdMarca, @IdCategoria, @Stock, @Activo);

			set @IdAutogenerado = SCOPE_IDENTITY();

			insert into DetalleProducto (ProductoId, FechaIngreso, PrecioCompra, PrecioVenta, CantidadCompra) values
			(@IdAutogenerado, getdate(), @PrecioCompra, @PrecioVenta, @CantidadCompra);

			set @Resultado = @IdAutogenerado;
			set @Mensaje = ''
		end
		else
		set @Mensaje = 'El producto ya existe'

	commit tran;

end try

begin catch
	IF @@TRANCOUNT > 0
        ROLLBACK TRAN;

	set @Mensaje = ERROR_MESSAGE();
	set @Resultado = 0;

end catch
GO
