/****** Object:  UserDefinedFunction [dbo].[fn_obtenerCarritoUsuario]    Script Date: 8/4/2026 18:33:47 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
Create function [dbo].[fn_obtenerCarritoUsuario](
@idUsuario int
)
returns table
as
return(
    select p.Id,
           m.Descripcion [DesMarca],
           p.Nombre,
           dp.PrecioVenta,
           c.Cantidad,
           p.RutaImagen,
           p.NombreImagen
    from CARRITO c
    inner join PRODUCTO p on p.Id = c.ProductoId
    inner join MARCA m on m.Id = p.MarcaId
    inner join DetalleProducto dp on dp.ProductoId = p.Id
    where c.IdUsuario = @idUsuario
    )
GO
