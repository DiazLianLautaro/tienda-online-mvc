	set @Resultado = 0
	if not exists (select * from USUARIO where Email = @Email)
	begin
		insert into USUARIO(Nombre,Apellido,Email,Clave,Telefono,ImagenPerfil,Activo,Reestablecer,EsAdmin) values
		(@Nombre,@Apellido,@Email,@Clave,'','',@Activo,0,0)

