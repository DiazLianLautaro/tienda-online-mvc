SET QUOTED_IDENTIFIER ON
GO
create proc [dbo].[sp_ReporteDashboard]
as
begin
	select
		(select COUNT(*) from USUARIO) [TotalCliente],
		(select ISNULL(SUM(cantidad),0) from DETALLE_VENTA) [TotalVenta],
		(select COUNT(*) from PRODUCTO) [TotalProducto]
end
