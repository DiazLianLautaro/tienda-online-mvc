/****** Object:  StoredProcedure [dbo].[sp_EliminarCarrito]    Script Date: 8/4/2026 18:33:47 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

Create proc [dbo].[sp_EliminarCarrito](
@IdUsuario int,
@IdProducto int,
@Resultado bit output
)
as
begin

    set @Resultado = 1
    declare @cantidadproducto int = (select Cantidad from CARRITO 
                                     where IdUsuario = @IdUsuario 
                                       and ProductoId = @IdProducto)

    BEGIN TRY

        BEGIN TRANSACTION OPERACION

        update PRODUCTO 
            set Stock = Stock + @cantidadproducto 
            where Id = @IdProducto

        delete top (1) from CARRITO 
            where IdUsuario = @IdUsuario 
              and ProductoId = @IdProducto

        COMMIT TRANSACTION OPERACION

    END TRY
    BEGIN CATCH
        set @Resultado = 0
        ROLLBACK TRANSACTION OPERACION
    END CATCH

end
GO
/****** Object:  StoredProcedure [dbo].[sp_EliminarCategoria]    Script Date: 8/4/2026 18:33:47 ******/
