/****** Object:  StoredProcedure [dbo].[sp_EditarCategoria]    Script Date: 8/4/2026 18:33:47 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
create proc [dbo].[sp_EditarCategoria](
@IdCategoria int,
@Descripcion varchar(100),
@Activo bit,
@Mensaje varchar(500) output,
@Resultado int output
)
as
begin
	set @Resultado = 0
	IF NOT EXISTS (SELECT * FROM CATEGORIA WHERE Descripcion = @Descripcion AND Id != @IdCategoria)
	begin
		update top (1) CATEGORIA set
		Descripcion = @Descripcion,
		Activo = @Activo
		where Id = @IdCategoria

		SET @Resultado = 1
	end
	else
		set @Mensaje = 'La categoria ya existe'
end
GO
/****** Object:  StoredProcedure [dbo].[sp_EditarMarca]    Script Date: 8/4/2026 18:33:47 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
create proc [dbo].[sp_EditarMarca](
@IdMarca int,
@Descripcion varchar(100),
@Activo bit,
@Mensaje varchar(500) output,
@Resultado int output
)
as
begin
	set @Resultado = 0
	IF NOT EXISTS (SELECT * FROM MARCA WHERE Descripcion = @Descripcion AND Id != @IdMarca)
	begin
		update top (1) MARCA set
		Descripcion = @Descripcion,
		Activo = @Activo
		where Id = @IdMarca

		SET @Resultado = 1
	end
	else
		set @Mensaje = 'La Marca ya existe'
end
GO
/****** Object:  StoredProcedure [dbo].[sp_EditarProducto]    Script Date: 8/4/2026 18:33:47 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE proc [dbo].[sp_EditarProducto](
@IdProducto int,
@Nombre varchar(100),
@Descripcion varchar(100),
@IdMarca varchar(100),
@IdCategoria varchar(100),
@Stock int,
@Activo bit,
@PrecioCompra decimal(10,2),
@PrecioVenta decimal(10,2),
@CantidadCompra int,
@Mensaje varchar(500) output,
@Resultado int output
)
as
begin try
	begin tran

		set @Resultado = 0
		if not exists (select * from PRODUCTO where Nombre = @Nombre and Id != @IdProducto)
		begin
			update PRODUCTO  set
			Nombre = @Nombre,
			Descripcion = @Descripcion,
			MarcaId = @IdMarca,
			CategoriaId = @IdCategoria,
			Stock = @Stock,
			Activo = @Activo
			where Id = @IdProducto

			update DetalleProducto set
			PrecioCompra = @PrecioCompra,
			PrecioVenta = @PrecioVenta,
			CantidadCompra = CantidadCompra
			where ProductoId = @IdProducto

			SET @Resultado = 1
		end
		else
		set @Mensaje = 'El nombre del producto ya existe'

	commit tran
end try

begin catch
	IF @@TRANCOUNT > 0
        ROLLBACK TRAN;

	SET @Resultado = 0
	set @Mensaje = 'Se produjo un error'

end catch
GO
/****** Object:  StoredProcedure [dbo].[sp_EditarUsuario]    Script Date: 8/4/2026 18:33:47 ******/
