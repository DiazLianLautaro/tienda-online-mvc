@Resultado int output
)
as
begin
	set @Resultado = 0
	if not exists (select * from PRODUCTO p inner join
	MARCA m on m.Id = p.MarcaId
	where p.MarcaId = @IdMarca)
	begin
		delete top (1) from MARCA where Id = @IdMarca
		set @Resultado = 1
