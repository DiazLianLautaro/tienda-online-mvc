
@{
    ViewBag.Title = "Blog";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header-->
<section id="sInicio">
    <header class="bg-dark p-md-4">
        <div class="container px-4 px-lg-5 my-5">
            <div class="text-center text-white">
                <h2 class="display-6 fw-bolder">Te invitamos a que nos conozcas!</h2>
                <h4 class="fw-bolder">Aquí encontrarás un blog sobre nosotros</h4>
                @*<p class="lead fw-normal text-white-50 mb-0">descripcion</p>*@
            </div>
        </div>
    </header>
</section>

<!--About-->
<section class="page-section bg-primary" id="about">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="text-white mt-0">We've got what you need!</h2>
                <hr class="divider divider-light" />
                <p class="text-white-75 mb-4">Start Bootstrap has everything you need to get your new website up and running in no time! Choose one of our open source, free to download, and easy to use themes! No strings attached!</p>
                <a class="btn btn-light btn-xl" href="#services">Servicios</a>
            </div>
        </div>
    </div>
</section>


<!-- Carousel -->
<div class="container my-5">
    <div id="carouselExampleCaptions" class="carousel slide carousel-custom" data-bs-ride="carousel">

        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="2"></button>
        </div>

        <div class="carousel-inner rounded shadow">
            <div class="carousel-item active">
                <img src="https://e01-elmundo.uecdn.es/assets/multimedia/imagenes/2021/09/08/16311009138426.png" class="d-block w-100 carousel-img" alt="img">
                <div class="carousel-caption">
                    <h5>First slide</h5>
                    <p>Contenido representativo</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="https://i0.wp.com/elplanetaurbano.com/wp-content/uploads/2023/03/Productos-sutentables.jpg?resize=1250%2C720&ssl=1" class="d-block w-100 carousel-img" alt="img">
                <div class="carousel-caption">
                    <h5>Second slide</h5>
                    <p>Contenido representativo</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="https://media.licdn.com/dms/image/v2/D5612AQFK2SR1n5wyzg/article-cover_image-shrink_720_1280/article-cover_image-shrink_720_1280/0/1736339829335?e=2147483647&v=beta&t=CK5GLWjG0zDz6wAElzjRF4HGNZOniwbHZF6qIq26hMM" class="d-block w-100 carousel-img" alt="img">
                <div class="carousel-caption">
                    <h5>Third slide</h5>
                    <p>Contenido representativo</p>
                </div>
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>

    </div>
</div>

<!--Services-->
<section class="page-section" id="services">
    <div class="container px-4 px-lg-5">
        <h2 class="text-center mt-0">At Your Service</h2>
        <hr class="divider" />
        <div class="row gx-4 gx-lg-5">
            <div class="col-lg-3 col-md-6 text-center">
                <div class="mt-5">
                    <div class="mb-2"><i class="bi-gem fs-1 text-primary"></i></div>
                    <h3 class="h4 mb-2">Sturdy Themes</h3>
                    <p class="text-muted mb-0">Our themes are updated regularly to keep them bug free!</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center">
                <div class="mt-5">
                    <div class="mb-2"><i class="bi-laptop fs-1 text-primary"></i></div>
                    <h3 class="h4 mb-2">Up to Date</h3>
                    <p class="text-muted mb-0">All dependencies are kept current to keep things fresh.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center">
                <div class="mt-5">
                    <div class="mb-2"><i class="bi-globe fs-1 text-primary"></i></div>
                    <h3 class="h4 mb-2">Ready to Publish</h3>
                    <p class="text-muted mb-0">You can use this design as is, or you can make changes!</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 text-center">
                <div class="mt-5">
                    <div class="mb-2"><i class="bi-heart fs-1 text-primary"></i></div>
                    <h3 class="h4 mb-2">Made with Love</h3>
                    <p class="text-muted mb-0">Is it really open source if it's not made with love?</p>
                </div>
            </div>
        </div>
    </div>
</section>


<!--Portafolio-->
<div id="portfolio">
    <div class="container-fluid p-0">
        <div class="row g-0">
            <div class="col-lg-4 col-sm-6">
                <a class="portfolio-box" href="" title="Proyecto">
                    <img src="https://www.univision.com/_next/image?url=https%3A%2F%2Fst1.uvnimg.com%2F35%2F28%2F624e5c084d01ac2f4cb81089d6d0%2Fcajas-y-productos.jpg&w=1280&q=75" alt="..." />
                    <div class="portfolio-box-caption">
                        <div class="project-category text-white-50">Visualizar</div>
                        <div class="project-name">Proyecto 1</div>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-sm-6">
                <a class="portfolio-box" href="" title="Proyecto">
                    <img src="https://media.istockphoto.com/id/1414801672/es/foto/caja-de-cart%C3%B3n-con-producto-cosm%C3%A9tico-en-frente-od-puerta-abierta-compra-online-y-concepto-de.jpg?s=612x612&w=0&k=20&c=h09o9zOOzXCE4RP71GHP8qsrE21oUQyxQvJf2vMhkmE=" alt="..." />
                    <div class="portfolio-box-caption">
                        <div class="project-category text-white-50">Visualizar</div>
                        <div class="project-name">Proyecto 2</div>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-sm-6">
                <a class="portfolio-box" href="" title="Proyecto">
                    <img src="https://www.bamboocosmeticos.com/wp-content/uploads/2024/11/cosmeticos-bamboo-store.jpg" alt="..." />
                    <div class="portfolio-box-caption">
                        <div class="project-category text-white-50">Visualizar</div>
                        <div class="project-name">Proyecto 3</div>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-sm-6">
                <a class="portfolio-box" href="" title="Proyecto">
                    <img src="https://img.freepik.com/fotos-premium/cosmeticos-naturales-cabello-cuidado-piel-champu-solido-aceites-cremas-mas_528985-6462.jpg?semt=ais_hybrid&w=740&q=80" alt="..." />
                    <div class="portfolio-box-caption">
                        <div class="project-category text-white-50">Visualizar</div>
                        <div class="project-name">Proyecto 4</div>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-sm-6">
                <a class="portfolio-box" href="" title="Proyecto">
                    <img src="https://bellezaideal.es/wp-content/uploads/2020/05/productos-belleza.jpeg" alt="..." />
                    <div class="portfolio-box-caption">
                        <div class="project-category text-white-50">Visualizar</div>
                        <div class="project-name">Proyecto 5</div>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-sm-6">
                <a class="portfolio-box" href="" title="Proyecto">
                    <img src="https://i0.wp.com/elplanetaurbano.com/wp-content/uploads/2023/03/Productos-de-belleza-sustentables.jpg?resize=640%2C359&ssl=1" alt="..." />
                    <div class="portfolio-box-caption p-3">
                        <div class="project-category text-white-50">Visualizar</div>
                        <div class="project-name">Proyecto 6</div>
                    </div>
                </a>
            </div>
        </div>
    </div>
    <hr class="divider" />
</div>


<!-- Call to action-->
@if (Session["Usuario"] != null)
{
    <section class="page-section bg-dark text-white">
        <div class="container px-4 px-lg-5 text-center">
            <h2 class="mb-4">Para saber más sobre nuestros servicios!</h2>
            <a class="btn btn-light btn-xl" href="@Url.Action("Contacto","Tienda")">Contactanos!</a>
        </div>
    </section>
}



<style>

    .portfolio-box {
        position: relative;
        display: block;
        width: 100%;
        height: 250px;
        overflow: hidden;
    }

        .portfolio-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }




    /*Carousel*/
    .carousel-custom {
        max-width: 800px; /* tamaño más amigable */
        margin: auto;
    }

    .carousel-item {
        transition: transform 0.2s ease-in-out;
    }

    .carousel-img {
        height: 400px; /* todas del mismo alto */
        object-fit: cover; /* recorte elegante */
        filter: brightness(85%); /* mejora contraste del texto */
    }

    .carousel-caption {
        background: rgba(0, 0, 0, 0.45);
        border-radius: 10px;
        padding: 10px 15px;
    }
</style>