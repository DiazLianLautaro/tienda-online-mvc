
@{
    ViewBag.Title = "Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a href="index.html">Resumen</a></li>
    <li class="breadcrumb-item active">Usuarios</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-users me-1"></i> Lista de Usuarios
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-12">
                <button type="button" class="btn btn-success" onclick="abrirModal(null)">Crear Nuevo</button>
            </div>
        </div>

        <hr />

        <table id="tabla" class="display cell-border" style="width: 100%">
            <thead>
                <tr>
                    <th>Nombres</th>
                    <th>Apellidos</th>
                    <th>Correo</th>
                    <th>Activo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>


<!-- Modal -->
<div class="modal fade" id="FormModal" tabindex="-1" aria-labelledby="exampleModalLabel" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Usuario</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <input id="txtid" type="hidden" value="0" />

                <div class="row g-2">

                    <div class="col-sm-6 mb-3">
                        <label for="txtNombres" class="form-label">Nombres</label>
                        <input type="text" class="form-control" id="txtNombres" autocomplete="off">
                    </div>

                    <div class="col-sm-6 mb-3">
                        <label for="txtApellidos" class="form-label">Apellidos</label>
                        <input type="text" class="form-control" id="txtApellidos" autocomplete="off">
                    </div>

                    <div class="col-sm-6 mb-3">
                        <label for="txtCorreo" class="form-label">Correo</label>
                        <input type="text" class="form-control" id="txtCorreo" autocomplete="off">
                    </div>

                    <div class="col-sm-6 mb-3">
                        <label for="cboActivo" class="form-label">Activo</label>
                        <select id="cboActivo" class="form-select">
                            <option value="1">Si</option>
                            <option value="0">No</option>
                        </select>
                    </div>

                </div>
                <div class="row mt-2">
                    <div class="col-12">
                        <div id="MensajeError" class="alert alert-danger" role="alert">
                            simple danger
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="Guardar()">Guardar</button>
            </div>
        </div>
    </div>
</div>


@section scripts{
    <script>

        var tabladata;
        var filaSeleccionada;

        //Manejo de datos de Usuarios en la tabla.
        tabladata = $("#tabla").DataTable({
            responsive: true,
            ordering: false,
            "ajax": {
                url: '@Url.Action("ListarUsuarios", "Home")',
                type: "GET",
                dataType: "json"
            },
            //Completa las filas en el tbody con datos.
            "columns": [
                { "data": "Nombres" },
                { "data": "Apellidos" },
                { "data": "Correo" },
                {
                    "data": "Activo", "render": function (valor) {
                        if (valor) {
                            return '<span class="badge text-bg-success">Si</span>'
                        } else {
                            return '<span class="badge text-bg-danger">No</span>'
                        }
                    }
                },
                //Botones Editar Eliminar.
                {
                    "defaultContent": '<button type="button" class="btn btn-primary btn-sm btn-editar"><i class="fas fa-pen me-1"></i></button>' +
                        '<button type="button" class="btn btn-danger btn-sm ms-2 btn-eliminar"><i class="fas fa-trash me-1"></i></button>',
                    "orderable": false,
                    "searchable": false, /*Para no buscarlo en la barra de búsqueda*/
                    "width": "90px"
                }
            ],
            language: {
                url: '//cdn.datatables.net/plug-ins/2.3.4/i18n/es-ES.json'
            }
        });


        //Abre el Modal
        function abrirModal(json) {

            //vaciar campos
            $("#txtid").val(0)
            $("#txtNombres").val("")
            $("#txtApellidos").val("")
            $("#txtCorreo").val("")
            $("#cboActivo").val(1)

            $("#MensajeError").hide();
            
            //if null, AGREGAR
            //if notnull, EDITAR
            if (json != null) {

                //El # es para hacer referencia a la etiqueta del input por medio de su atributo Id.
                $("#txtid").val(json.IdUsuario)
                $("#txtNombres").val(json.Nombres)
                $("#txtApellidos").val(json.Apellidos)
                $("#txtCorreo").val(json.Correo)
                $("#cboActivo").val(json.Activo == true ? 1 : 0)

            }

            $("#FormModal").modal("show");
        }


        //Botón de editar
        $("#tabla tbody").on("click",'.btn-editar', function () {

            filaSeleccionada = $(this).closest("tr");

            var data = tabladata.row(filaSeleccionada).data();

            abrirModal(data)
        })

        //Botón de eliminar
        $("#tabla tbody").on("click", '.btn-eliminar', function () {

            var usuarioSeleccionado = $(this).closest("tr");

            var data = tabladata.row(usuarioSeleccionado).data();

            swal({
                title: "¿Estás Seguro/a?",
                text: "¿Desea Eliminar el Usuario?",
                type: "warning",
                showCancelButton: true,
                confirmButtonClass: "btn-danger",
                confirmButtonText: "Si, Seguro/a",
                cancelButtonText: "No",
                closeOnConfirm: true
            },
                function () {
                    jQuery.ajax({
                        url: '@Url.Action("EliminarUsuario", "Home")',
                        type: "POST",
                        data: JSON.stringify({ id: data.IdUsuario }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (data) {

                            if (data.resultado) {                         //draw "dibuja" inmediatamente el cambio
                                tabladata.row(usuarioSeleccionado).remove().draw();
                            }
                            else {
                                swal("No se pudo eleminar", data.mensaje, "error");
                            }
                        },
                        error: function (error) {
                            console.log(error)
                        },
                        beforeSend: function () {

                        }
                    });

                    swal("Deleted!", "Your imaginary file has been deleted.", "success");
                });

        })


        //Botón Guardar formulario Modal
        function Guardar() {

            var Usuario = {

                IdUsuario: $("#txtid").val(),
                Activo: $("#cboActivo").val() == 1 ? true : false,
                Apellidos: $("#txtApellidos").val(),
                Correo: $("#txtCorreo").val(),
                Nombres: $("#txtNombres").val()
            }

            jQuery.ajax({
                url: '@Url.Action("GuardarUsuario", "Home")',
                type: "POST",
                data: JSON.stringify({objeto : Usuario}),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (data) {

                    $(".modal-body").LoadingOverlay("hide");

                    //si id == 0, nuevo Usuario
                    if (Usuario.IdUsuario == 0) {

                        if (data.resultado != 0) {
                            Usuario.IdUsuario = data.resultado;
                            tabladata.row.add(Usuario).draw(false);
                            $("#FormModal").modal("hide");
                        }
                        else {
                            $("#MensajeError").text(data.mensaje);
                            $("#MensajeError").show();               
                        }



                    }
                    //si no, editar Usuario
                    else {
                        if (data.resultado) {
                            tabladata.row(filaSeleccionada).data(Usuario).draw(false);
                            filaSeleccionada = null;
                            $("#FormModal").modal("hide");
                        }
                        else {
                            $("#MensajeError").text(data.mensaje);
                            $("#MensajeError").show();
                        }
                    }
                    //console.log(data)
                },
                error: function (error) {
                    $(".modal-body").LoadingOverlay("hide");
                    $("#MensajeError").text("Error Ajax");
                    $("#MensajeError").show(); 
                },
                beforeSend: function () {
                    //Pantalla de carga
                    $(".modal-body").LoadingOverlay("show",{
                        imageResizeFactor: 2,
                        text: "Cargando...",
                        size: 14
                    })
                }
            });


            

            //$("#FormModal").modal("hide");
        }

    </script>

}

